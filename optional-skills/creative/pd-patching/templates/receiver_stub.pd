#N canvas 60 60 720 470 12;
#X obj 30 40 netreceive 9999;
#X obj 30 92 route pd-target_canvas pd pd-rec;
#X obj 30 150 send pd-target_canvas;
#X obj 210 150 send pd;
#X obj 300 150 send pd-rec;
#X obj 410 150 print pd-net-in;
#N canvas 340 120 500 380 target_canvas 0;
#X restore 30 220 pd target_canvas;
#X text 300 34 opens a TCP socket on port 9999;
#X text 300 86 splits the receiver name off the front of each message and forwards the rest;
#X text 300 138 outlet 0 edits the canvas \, 1 -> global pd \, 2 -> pd-rec (WAV record control) \, 3 (unmatched) -> print;
#X text 30 260 Dynamically built objects land inside the [pd target_canvas] subpatch above.;
#X text 30 300 Client sends receiver-addressed lines WITHOUT a leading semicolon \, e.g. pd-target_canvas obj 100 50 osc~ 440 -- netreceive does not auto-route a leading semicolon \, so [route]+[send] does the dispatch.;
#X text 30 380 pd-rec routes WAV control (open/start/stop) to a [r pd-rec] the patch creates via to_dac(record=True). A plain word falls to [print pd-net-in] \, confirming the handshake.;
#X connect 0 0 1 0;
#X connect 1 0 2 0;
#X connect 1 1 3 0;
#X connect 1 2 4 0;
#X connect 1 3 5 0;
